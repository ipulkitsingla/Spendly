# Spendly API — copy to .env locally, or set each key in Vercel → Project → Settings → Environment Variables

# HTTP port (local dev). Vercel sets PORT automatically when applicable.
PORT=5000

# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb+srv://singlapulkit1103_db_user:pulkit2005@spendly.browrht.mongodb.net/

# Long random string for signing JWTs (generate e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated list of allowed browser origins for CORS (your Vercel app URLs).
# Example: https://spendly.vercel.app,https://spendly-git-main-yourteam.vercel.app
# Leave unset for development (allows any origin).
FRONTEND_URL=http://localhost:3000

# SMTP email settings (required for reminders, monthly statements, and welcome emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=moneyspendly@gmail.com
SMTP_PASS=hjudvfweixrjdku
EMAIL_FROM=Spendly <moneyspendly@gmail.com>

# Timezone for scheduled reminders / monthly statement cron
REMINDER_TIMEZONE=Asia/Kolkata