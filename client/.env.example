# Spendly client (Vite) — copy to .env.local for local overrides, or set in Vercel → Project → Settings → Environment Variables

# Production / preview: full URL of your API (no trailing slash).
# Leave empty in dev to use Vite’s proxy to localhost (see vite.config.js).
# Example: https://spendly-api.vercel.app
VITE_API_URL=http://localhost:5000